#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Prefer installed binary next to this script
if [ -x "$SCRIPT_DIR/context-mode.exe" ]; then
    exec "$SCRIPT_DIR/context-mode.exe" "$@"
elif [ -x "$SCRIPT_DIR/context-mode" ]; then
    exec "$SCRIPT_DIR/context-mode" "$@"
fi

# Fallback to cargo-built debug/release binary
for target in "$SCRIPT_DIR/../../../target/release/context-mode" "$SCRIPT_DIR/../../../target/debug/context-mode" "$SCRIPT_DIR/../../../target/release/context-mode.exe" "$SCRIPT_DIR/../../../target/debug/context-mode.exe"; do
    if [ -x "$target" ]; then
        exec "$target" "$@"
    fi
done

echo "Error: context-mode binary not found." >&2
echo "Run: cargo build --bin context-mode" >&2
exit 1
