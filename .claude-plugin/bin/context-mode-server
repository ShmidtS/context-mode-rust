#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Prefer installed binary next to this script
if [ -x "$SCRIPT_DIR/context-mode-server.exe" ]; then
    exec "$SCRIPT_DIR/context-mode-server.exe" "$@"
elif [ -x "$SCRIPT_DIR/context-mode-server" ]; then
    exec "$SCRIPT_DIR/context-mode-server" "$@"
fi

# Fallback to cargo-built debug/release binary
for target in "$SCRIPT_DIR/../../target/release/context-mode-server" "$SCRIPT_DIR/../../target/debug/context-mode-server" "$SCRIPT_DIR/../../target/release/context-mode-server.exe" "$SCRIPT_DIR/../../target/debug/context-mode-server.exe"; do
    if [ -x "$target" ]; then
        exec "$target" "$@"
    fi
done

echo "Error: context-mode-server binary not found." >&2
echo "Run: cargo build --bin context-mode-server" >&2
exit 1
